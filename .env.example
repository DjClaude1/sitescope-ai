# ========== Required ==========
# Get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
# Optional override for the Gemini model. If unset we try:
#   gemini-2.0-flash -> gemini-flash-latest -> gemini-2.5-flash
# and fall back on "model not found" errors.
GEMINI_MODEL=

# Public URL of your deployed site (used for PayPal return_url, emails)
NEXT_PUBLIC_APP_URL=https://sitescope-ai.vercel.app

# ========== Optional: Supabase (for auth + audit history + Pro billing) ==========
# Create a free project at https://supabase.com
# Run supabase/schema.sql in the SQL editor after creating the project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ========== Optional: PayPal subscriptions (Pro plan) ==========
# Create a plan at https://www.paypal.com/billing/plans
# Use sandbox credentials for testing: PAYPAL_ENV=sandbox
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_PLAN_ID=
# Webhook ID from the PayPal dashboard. REQUIRED for webhook signature
# verification — without it the webhook will reject every request with 401.
PAYPAL_WEBHOOK_ID=
# Set to 1 ONLY for local smoke tests where you can't verify signatures.
# MUST be unset or 0 in production.
PAYPAL_WEBHOOK_SKIP_VERIFY=

# ========== Optional: weekly monitoring emails ==========
# Resend free tier: 3k emails/month — https://resend.com
RESEND_API_KEY=
RESEND_FROM="SiteScope <alerts@your-domain.com>"

# Cron auth (Vercel Cron automatically sends Authorization: Bearer <secret>)
CRON_SECRET=
